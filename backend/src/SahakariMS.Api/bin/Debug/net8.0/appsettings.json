{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=sahakari_ms;Username=sahakari;Password=sahakari_pass;",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "JwtSettings": {
    "SecretKey": "SahakariMS_SuperSecret_Key_Change_In_Production_Min32Chars!",
    "Issuer": "SahakariMS",
    "Audience": "SahakariMS",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sahakari-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Hangfire": {
    "DashboardPath": "/hangfire"
  }
}
